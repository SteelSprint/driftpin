// nodeHasAllEdgesChecked reports whether every baseline edge touching nodeID
// is either consistent (both endpoint hashes match baseline) or covered by a
// matching resolution entry. Used by collapse to decide which nodes can be
// re-baselined.
func nodeHasAllEdgesChecked(
	nodeID string,
	edges []Edge,
	specsByID map[string]*Spec,
	markersByID map[string]*Marker,
	resolutionsByEdge map[string]EdgeResolution,
	scan Scan,
) bool {
	for _, e := range edges {
		if e.From != nodeID && e.To != nodeID {
			continue
		}
		if edgeIsUnchecked(e, specsByID, markersByID, resolutionsByEdge, scan) {
			return false
		}
	}
	return true
}

